# Final Elice Serverless runtime configuration
LLM_PROVIDER=elice
EMBEDDING_PROVIDER=elice

ELICE_API_KEY=
ELICE_BASE_URL=https://mlapi.run/{chat-endpoint-id}/v1
ELICE_CHAT_MODEL=openai/gpt-5-mini
ELICE_EMBEDDING_BASE_URL=https://mlapi.run/{embedding-endpoint-id}
ELICE_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional: map a requested model to a different Elice endpoint.
# Format: model_id=url;model_id=url
# ELICE_MODEL_ENDPOINTS=openai/gpt-5-nano=https://mlapi.run/{nano-endpoint-id}/v1

# Optional: Azure OpenAI provider for development verification before Elice credit is ready.
# LLM_PROVIDER=azure
# EMBEDDING_PROVIDER=azure
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://{resource-name}.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=
# AZURE_OPENAI_MODEL_NAME=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=

# Optional: cost-free local test/CI fallback.
# LLM_PROVIDER=mock
# EMBEDDING_PROVIDER=local

# Retrieval defaults; safe to omit if defaults are acceptable.
RAG_TOP_K=5
RAG_MIN_SCORE=0.08
RAG_MAX_CONTEXT_CHARS=12000
